# Cerebro bootstrap configuration

# HTTP
CEREBRO_HTTP_ADDR=:8080
CEREBRO_SHUTDOWN_TIMEOUT=10s

# API auth. Enable in any shared or production deployment.
CEREBRO_API_AUTH_ENABLED=false
# Comma-separated key[:principal[:tenant_id]] entries. Example only; replace with random secrets.
CEREBRO_API_KEYS=
# Optional tenant allowlist for unscoped API keys.
CEREBRO_ALLOWED_TENANTS=

# Append log: NATS JetStream
CEREBRO_APPEND_LOG_DRIVER=
CEREBRO_JETSTREAM_URL=
CEREBRO_JETSTREAM_SUBJECT_PREFIX=events

# State store: Postgres
CEREBRO_STATE_STORE_DRIVER=
CEREBRO_POSTGRES_DSN=

# Graph store: Neo4j/Aura
CEREBRO_GRAPH_STORE_DRIVER=
CEREBRO_NEO4J_URI=
CEREBRO_NEO4J_USERNAME=
CEREBRO_NEO4J_PASSWORD=
CEREBRO_NEO4J_DATABASE=

# Legacy Kuzu configuration is intentionally unsupported.
# CEREBRO_KUZU_PATH must remain unset.
