# =============================================================================
# SNOWFLAKE (Primary Data Store) - Key-pair authentication required
# =============================================================================
SNOWFLAKE_ACCOUNT=your-account.us-east-1
SNOWFLAKE_USER=CEREBRO_APP
SNOWFLAKE_PRIVATE_KEY=<paste-snowflake-private-key-pem>
SNOWFLAKE_ROLE=CEREBRO_ROLE
SNOWFLAKE_DATABASE=CEREBRO
SNOWFLAKE_SCHEMA=CEREBRO
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# =============================================================================
# CLOUD PROVIDERS (for native sync)
# =============================================================================

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# GCP
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Azure
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# =============================================================================
# API SERVER
# =============================================================================
API_PORT=8080
LOG_LEVEL=info
POLICIES_PATH=policies
API_AUTH_ENABLED=false
# Comma-separated key[:user-id] entries, e.g. "key1:svc-ci,key2:security-bot"
API_KEYS=
# Comma-separated list of allowed origins; leave blank to disable CORS middleware
API_CORS_ALLOWED_ORIGINS=

# =============================================================================
# AI AGENTS (optional - enables AI-powered security analysis)
# =============================================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# =============================================================================
# TICKETING INTEGRATIONS (optional)
# =============================================================================

# Jira
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT=SEC

# Linear
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# =============================================================================
# CUSTOM PROVIDERS (optional - additional security data sources)
# =============================================================================

# CrowdStrike
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=

# Okta
OKTA_DOMAIN=your-domain.okta.com
OKTA_API_TOKEN=

# =============================================================================
# NOTIFICATIONS (optional - alerting on findings)
# =============================================================================

# Slack (incoming webhook URL)
SLACK_WEBHOOK_URL=

# PagerDuty (Events API v2 routing key)
PAGERDUTY_ROUTING_KEY=

# Slack request signature validation secret (for /api/v1/slack/commands)
SLACK_SIGNING_SECRET=

# =============================================================================
# SCHEDULED SCANNING (optional - automatic policy evaluation)
# =============================================================================

# Scan interval (e.g., "1h", "30m", "6h")
SCAN_INTERVAL=

# Comma-separated list of tables to scan
SCAN_TABLES=aws_s3_buckets,aws_ec2_instances,aws_iam_users

# =============================================================================
# API RATE LIMITING (optional)
# =============================================================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=1h

# =============================================================================
# DISTRIBUTED JOB WORKERS (optional)
# =============================================================================
JOB_QUEUE_URL=
JOB_TABLE_NAME=
JOB_REGION=
JOB_WORKER_CONCURRENCY=4

# See docs/CONFIGURATION.md for the complete environment variable matrix.
