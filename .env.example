# =============================================================================
# SNOWFLAKE (Primary Data Store) - Key-pair authentication required
# =============================================================================
SNOWFLAKE_ACCOUNT=your-account.us-east-1
SNOWFLAKE_USER=CEREBRO_APP
SNOWFLAKE_PRIVATE_KEY=<paste-snowflake-private-key-pem>
SNOWFLAKE_ROLE=CEREBRO_ROLE
SNOWFLAKE_DATABASE=CEREBRO
SNOWFLAKE_SCHEMA=CEREBRO
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# =============================================================================
# CLOUD PROVIDERS (for native sync)
# =============================================================================

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# GCP
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Azure
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# =============================================================================
# API SERVER
# =============================================================================
API_PORT=8080
LOG_LEVEL=info
POLICIES_PATH=policies
QUERY_POLICY_ROW_LIMIT=1000
API_AUTH_ENABLED=true
# Comma-separated key[:user-id] entries, e.g. "key1:svc-ci,key2:security-bot"
API_KEYS=
# Local development opt-out (requires LOG_LEVEL=debug or CEREBRO_DEV_MODE_ACK=1)
CEREBRO_DEV_MODE=
CEREBRO_DEV_MODE_ACK=
# CLI API mode: auto (default), api (require API), direct (bypass API)
CEREBRO_CLI_MODE=auto
# CLI API endpoint and auth (used when CEREBRO_CLI_MODE is auto/api)
CEREBRO_API_URL=http://127.0.0.1:8080
CEREBRO_API_KEY=
# Optional HTTP timeout for CLI->API requests
CEREBRO_API_TIMEOUT=15s
# Optional periodic secret refresh (e.g. "5m"); set to 0 to disable polling.
# You can also trigger immediate reload with: `kill -HUP <cerebro-pid>`
CEREBRO_SECRETS_RELOAD_INTERVAL=0
# Comma-separated list of allowed origins; leave blank to disable CORS middleware
API_CORS_ALLOWED_ORIGINS=

# OpenTelemetry tracing (optional)
CEREBRO_OTEL_ENABLED=false
CEREBRO_OTEL_SERVICE_NAME=cerebro
# OTLP endpoint in host:port format (e.g. localhost:4318)
CEREBRO_OTEL_EXPORTER_OTLP_ENDPOINT=
CEREBRO_OTEL_EXPORTER_OTLP_INSECURE=false
# Comma-separated key=value headers
CEREBRO_OTEL_EXPORTER_OTLP_HEADERS=
CEREBRO_OTEL_SAMPLE_RATIO=1.0
CEREBRO_OTEL_EXPORT_TIMEOUT=5s

# =============================================================================
# AI AGENTS (optional - enables AI-powered security analysis)
# =============================================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# =============================================================================
# TICKETING INTEGRATIONS (optional)
# =============================================================================

# Jira
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT=SEC
JIRA_CLOSE_TRANSITIONS=Done,Closed,Resolve Issue

# Linear
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# =============================================================================
# CUSTOM PROVIDERS (optional - additional security data sources)
# =============================================================================

# CrowdStrike
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=

# Okta
OKTA_DOMAIN=your-domain.okta.com
OKTA_API_TOKEN=

# =============================================================================
# NOTIFICATIONS (optional - alerting on findings)
# =============================================================================

# Slack (incoming webhook URL)
SLACK_WEBHOOK_URL=

# PagerDuty (Events API v2 routing key)
PAGERDUTY_ROUTING_KEY=

# Slack request signature validation secret (for /api/v1/slack/commands)
SLACK_SIGNING_SECRET=

# =============================================================================
# SCHEDULED SCANNING (optional - automatic policy evaluation)
# =============================================================================

# Scan interval (e.g., "1h", "30m", "6h")
SCAN_INTERVAL=

# Security digest notification interval (e.g., "24h", "168h")
SECURITY_DIGEST_INTERVAL=

# Comma-separated list of tables to scan
SCAN_TABLES=aws_s3_buckets,aws_ec2_instances,aws_iam_users

# Retention cleanup job interval (defaults to 24h)
CEREBRO_RETENTION_JOB_INTERVAL=24h

# Optional retention windows (days, 0 disables cleanup for that dataset)
CEREBRO_AUDIT_RETENTION_DAYS=0
CEREBRO_SESSION_RETENTION_DAYS=0
CEREBRO_GRAPH_RETENTION_DAYS=0
CEREBRO_ACCESS_REVIEW_RETENTION_DAYS=0

# =============================================================================
# API RATE LIMITING (optional)
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=1h

# =============================================================================
# DISTRIBUTED JOB WORKERS (optional)
# =============================================================================
# Requires Postgres job state plus NATS JetStream connectivity
JOB_DATABASE_URL=
NATS_URLS=nats://127.0.0.1:4222
JOB_NATS_STREAM=CEREBRO_JOBS
JOB_NATS_SUBJECT=cerebro.jobs
JOB_NATS_CONSUMER=job-worker
JOB_WORKER_CONCURRENCY=4
JOB_VISIBILITY_TIMEOUT=30s
JOB_POLL_WAIT=10s
JOB_MAX_ATTEMPTS=3

# See docs/CONFIGURATION.md for the complete environment variable matrix.
