{
  "id": "k8s-ingress-no-authentication",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Kubernetes Ingress No Authentication",
  "description": "Kubernetes Ingress lacks authentication annotations",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "kubernetes::networking::ingress",
  "conditions": [
    "!(contains_value(path(resource, \"annotations\"), \"nginx.ingress.kubernetes.io/auth-url\"))",
    "!(contains_value(path(resource, \"annotations\"), \"nginx.ingress.kubernetes.io/auth-signin\"))",
    "!(contains_value(path(resource, \"annotations\"), \"traefik.ingress.kubernetes.io/router.middlewares\"))"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "api",
    "kubernetes",
    "ingress",
    "authentication"
  ],
  "remediation": "Configure external authentication via ingress annotations or use a service mesh.",
  "risk_categories": [
    "IDENTITY_RISK"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-2",
        "IA-5"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "8.3",
        "8.4"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "6"
      ]
    }
  ]
}
