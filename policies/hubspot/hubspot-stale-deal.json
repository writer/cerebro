{
  "id": "hubspot-stale-deal",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Stale High-Value Deal",
  "description": "Flags high-value open deals with no recent activity.",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "hubspot::deal",
  "conditions": [
    "cmp_gt(path(resource, \"properties.days_since_last_activity\"), 21)",
    "cmp_gt(path(resource, \"properties.amount\"), 50000)",
    "cmp_ne(path(resource, \"properties.dealstage\"), \"closedwon\")",
    "cmp_ne(path(resource, \"properties.dealstage\"), \"closedlost\")"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "revenue",
    "pipeline-hygiene",
    "hubspot"
  ]
}
