{
  "id": "hubspot-no-next-step",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Open Deal Without Next Step",
  "description": "Flags active deals missing a defined next-step field.",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "hubspot::deal",
  "conditions": [
    "cmp_ne(path(resource, \"properties.dealstage\"), \"closedwon\")",
    "cmp_ne(path(resource, \"properties.dealstage\"), \"closedlost\")",
    "!exists_path(resource, \"properties.hs_next_step\")"
  ],
  "condition_format": "cel",
  "severity": "low",
  "tags": [
    "pipeline-hygiene",
    "hubspot"
  ]
}
