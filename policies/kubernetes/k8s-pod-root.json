{
  "id": "k8s-pod-no-run-as-root",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "K8s Pod No Run As Root",
  "description": "Pods should not run containers as root user",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "kubernetes::pod",
  "conditions": [
    "cmp_ne(path(resource, \"spec.security_context.run_as_non_root\"), true)",
    "cmp_eq(path(resource, \"spec.containers.security_context.run_as_user\"), 0)"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "cis-k8s-5.2.6",
    "pod-security",
    "root"
  ],
  "remediation": "Set runAsNonRoot: true and specify a non-zero runAsUser.",
  "risk_categories": [
    "IDENTITY_RISK",
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "CIS Kubernetes Benchmark",
      "controls": [
        "5.2.6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Persistence",
      "technique": "T1098"
    },
    {
      "tactic": "Privilege Escalation",
      "technique": "T1078"
    }
  ]
}
