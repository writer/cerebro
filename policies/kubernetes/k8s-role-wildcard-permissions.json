{
  "id": "k8s-role-wildcard-permissions",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Kubernetes Role with Wildcard Permissions",
  "description": "Role grants wildcard (*) permissions on resources, verbs, or API groups.",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "k8s::role",
  "conditions": [
    "list_value(path(resource, \"rules\")).exists(item, (contains_value(path(item, \"resources\"), \"*\")) || (contains_value(path(item, \"verbs\"), \"*\")) || (contains_value(path(item, \"api_groups\"), \"*\")))"
  ],
  "condition_format": "cel",
  "severity": "low",
  "tags": [
    "kubernetes",
    "rbac",
    "least-privilege"
  ],
  "remediation": "Replace wildcard role permissions with explicit resources, verbs, and API groups.",
  "risk_categories": [
    "PRIVILEGE_ESCALATION",
    "IDENTITY_RISK"
  ]
}
