{
  "id": "k8s-secrets-in-secrets-not-env",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "K8s Secrets Via Secret Objects",
  "description": "Sensitive data should be stored in Secret objects, not environment variables",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "kubernetes::pod",
  "conditions": [
    "matches_value(path(resource, \"spec.containers.env.name\"), \"(?i)(password|secret|api_key|token|credential)\")",
    "cmp_eq(path(resource, \"spec.containers.env.value_from.secret_key_ref\"), null)"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "secrets",
    "security",
    "credentials"
  ],
  "remediation": "Use secretKeyRef to reference secrets instead of inline values.",
  "risk_categories": [
    "UNPROTECTED_DATA",
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "8.6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1078"
    },
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    },
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}
