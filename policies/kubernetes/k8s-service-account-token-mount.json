{
  "id": "k8s-service-account-token-mount",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Kubernetes Pod Auto-Mounts Service Account Token",
  "description": "Pod automatically mounts a service account token that may not be needed",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "k8s::core::pod",
  "conditions": [
    "cmp_ne(path(resource, \"spec.automount_service_account_token\"), false)",
    "!(in_list(path(resource, \"spec.service_account_name\"), [\"default\"]))"
  ],
  "condition_format": "cel",
  "severity": "low",
  "tags": [
    "kubernetes",
    "security",
    "least-privilege",
    "cis-k8s-5.1.6"
  ],
  "remediation": "Set automountServiceAccountToken: false in pod spec if the pod doesn't need to access the Kubernetes API. Create minimal RBAC roles for pods that do need API access.",
  "risk_categories": [
    "PRIVILEGE_ESCALATION"
  ],
  "frameworks": [
