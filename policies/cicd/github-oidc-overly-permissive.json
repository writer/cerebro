{
  "id": "github-oidc-overly-permissive",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GitHub Actions OIDC Overly Permissive",
  "description": "AWS IAM role trust policy for GitHub OIDC allows any repository or branch",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::iam::role",
  "conditions": [
    "contains_value(path(resource, \"assume_role_policy\"), \"token.actions.githubusercontent.com\")",
    "(contains_value(path(resource, \"assume_role_policy\"), \"sub' == '*\")) || (!(contains_value(path(resource, \"assume_role_policy\"), \"repo:\")))"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "cicd",
    "github-actions",
    "oidc",
    "iam",
    "supply-chain"
  ],
  "remediation": "Restrict the OIDC trust policy to specific repositories and branches using the sub condition.",
  "risk_categories": [
    "IDENTITY_RISK",
    "LATERAL_MOVEMENT"
  ],
