{
  "id": "aws-codebuild-public-logs",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "AWS CodeBuild Public Build Logs",
  "description": "CodeBuild project has publicly accessible build logs",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::codebuild::project",
  "conditions": [
    "cmp_eq(path(resource, \"logs_config.cloud_watch_logs.status\"), \"ENABLED\")",
    "cmp_eq(path(resource, \"logs_config.s3_logs.encryption_disabled\"), true)"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "cicd",
    "codebuild",
    "logging",
    "data-exposure"
  ],
  "remediation": "Enable encryption for CodeBuild logs and restrict S3 bucket access.",
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AU-2",
        "AU-12",
        "AC-2",
        "AC-6"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "10.2",
        "10.3",
        "7.2"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC4",
        "CC7",
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "8",
        "5",
        "6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1190"
    },
    {
      "tactic": "Execution",
      "technique": "T1059"
    },
    {
      "tactic": "Defense Evasion",
      "technique": "T1562"
    },
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}
