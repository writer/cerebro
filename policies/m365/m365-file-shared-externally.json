{
  "id": "m365-file-shared-externally",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Microsoft 365 File Shared Externally",
  "description": "SharePoint site or OneDrive file is shared with external users outside the organization",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "m365::sharepoint::site",
  "conditions": [
    "cmp_eq(path(resource, \"external_sharing_enabled\"), true)",
    "cmp_gt(path(resource, \"external_user_count\"), 0)"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "m365",
    "sharepoint",
    "data-exposure",
    "external-sharing",
    "nist-ac-3"
  ],
  "remediation": "Review external sharing permissions. Remove unauthorized external access. Use expiring sharing links. Configure tenant-level sharing restrictions.",
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "UNPROTECTED_DATA"
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1190"
    },
    {
      "tactic": "Persistence",
      "technique": "T1098"
    },
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}
