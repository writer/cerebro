{
  "id": "m365-guest-admin",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Microsoft 365 Guest User with Admin Role",
  "description": "External guest user has been assigned an administrative role in the tenant",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "m365::directory::user",
  "conditions": [
    "cmp_eq(path(resource, \"user_type\"), \"Guest\")",
    "list_value(path(resource, \"directory_roles\")).exists(item, cmp_eq(path(item, \"is_privileged\"), true))"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "m365",
    "identity",
    "privileged-access",
    "guest-user",
    "nist-ac-6"
  ],
  "remediation": "Remove admin roles from guest users immediately. Guest users should not have elevated privileges. Create internal accounts if external admin access is required.",
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "IDENTITY_RISK",
    "PRIVILEGE_ESCALATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-2",
        "AC-6"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "7.2"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "5",
        "6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1190"
    },
