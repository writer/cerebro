{
  "id": "stripe-payment-failure-streak",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Consecutive Payment Failures",
  "description": "Detects subscriptions in past_due state with repeated payment failures.",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "stripe::subscription",
  "conditions": [
    "cmp_eq(path(resource, \"past_due\"), true)",
    "cmp_gt(path(resource, \"failed_payment_count\"), 2)"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "churn-risk",
    "revenue",
    "stripe"
  ]
}
