{
  "id": "stripe-trial-no-payment-method",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Trial Ending Without Payment Method",
  "description": "Flags trial subscriptions nearing expiration without a default payment method.",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "stripe::subscription",
  "conditions": [
    "cmp_eq(path(resource, \"status\"), \"trialing\")",
    "cmp_lt(path(resource, \"days_until_trial_end\"), 7)",
    "cmp_eq(path(resource, \"default_payment_method\"), null)"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "conversion",
    "revenue",
    "stripe"
  ]
}
