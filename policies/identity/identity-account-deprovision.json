{
  "id": "identity-account-deprovision",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Terminated User Accounts Deprovisioned",
  "description": "User accounts in cloud and SaaS systems should be deprovisioned within SLA when the associated employee is terminated in the HRIS",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "identity_user_accounts",
  "conditions": [
    "cmp_eq(path(resource, \"employee_status\"), path(resource, \"TERMINATED\"))",
    "cmp_eq(path(resource, \"account_active\"), true)",
    "cmp_gt(path(resource, \"days_since_termination\"), 3)"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "identity",
    "offboarding",
    "access-management",
    "user-lifecycle"
  ],
  "remediation": "Immediately deactivate or remove the user account from the system. Review access logs for any suspicious activity during the gap period",
  "remediation_steps": [
    "Identify the user account that needs deprovisioning",
    "Review the HRIS termination date",
    "Disable/deactivate the account in the target system",
    "Revoke all active sessions and tokens",
    "Document the action in the offboarding ticket"
  ],
  "risk_categories": [
    "IDENTITY_RISK"
  ],
  "frameworks": [
