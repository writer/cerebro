{
  "id": "identity-offboarding-sla",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Offboarding Completed Within SLA",
  "description": "Employee offboarding should be completed within the defined SLA (typically 24-72 hours) after termination date",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "hris_terminations",
  "conditions": [
    "cmp_ne(path(resource, \"offboarding_complete\"), true)",
    "cmp_gt(path(resource, \"days_since_termination\"), 3)"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "identity",
    "offboarding",
    "hr",
    "compliance"
  ],
  "remediation": "Complete all offboarding tasks immediately including access revocation, equipment return, and exit documentation",
  "remediation_steps": [
    "Review the offboarding checklist for the terminated employee",
    "Revoke all remaining system access",
    "Disable identity provider account",
    "Recover company equipment",
    "Complete exit interview documentation",
    "Mark offboarding as complete in HRIS"
  ],
  "risk_categories": [
    "IDENTITY_RISK"
  ],
