{
  "id": "github-repo-secrets-exposure",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GitHub Repository Secrets in Workflow Logs",
  "description": "Repository workflow may expose secrets in logs through echo or debug statements",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "github::workflow",
  "conditions": [
    "(matches_value(path(resource, \"content\"), \"echo.*\\\\$\\\\{\\\\{.*secrets\\\\.\")) || (matches_value(path(resource, \"content\"), \"print.*secrets\\\\.\")) || (contains_value(path(resource, \"content\"), \"::debug::\"))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "github",
    "actions",
    "secrets",
    "logging"
  ],
  "remediation": "Remove debug statements that expose secrets. Use GitHub's secret masking. Never echo secrets directly. Use ACTIONS_STEP_DEBUG only in private repos.",
  "risk_categories": [
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AU-2",
        "AU-12",
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
