{
  "id": "github-code-scanning-critical",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GitHub Code Scanning Critical Alert",
  "description": "Repository has critical code scanning alert from CodeQL or third-party scanner",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "github::code_scanning_alert",
  "conditions": [
    "(cmp_eq(path(resource, \"rule.severity\"), \"critical\")) || (cmp_eq(path(resource, \"rule.security_severity_level\"), \"critical\"))",
    "cmp_eq(path(resource, \"state\"), \"open\")"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "devsecops",
    "sast",
    "code-scanning",
    "codeql"
  ],
  "remediation": "Fix the vulnerability identified by the code scanner.",
  "mitre_attack": [
    {
      "tactic": "Execution",
      "technique": "T1059"
    }
  ]
}
