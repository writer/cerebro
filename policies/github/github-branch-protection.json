{
  "id": "github-repo-branch-protection",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GitHub Repository Branch Protection",
  "description": "GitHub repository default branch lacks branch protection rules",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "github::repository",
  "conditions": [
    "cmp_ne(path(resource, \"default_branch_protection.enabled\"), true)"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "devsecops",
    "github",
    "branch-protection",
    "cis-github-1.1.3"
  ],
  "remediation": "Enable branch protection rules for the default branch requiring reviews and status checks.",
  "frameworks": [
    {
      "name": "CIS GitHub Benchmark",
      "controls": [
        "1.1.3"
      ]
    }
  ]
}
