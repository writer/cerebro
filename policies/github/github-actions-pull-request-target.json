{
  "id": "github-actions-dangerous-trigger",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GitHub Actions Dangerous Trigger",
  "description": "Workflow uses pull_request_target trigger which can expose secrets to forked PRs",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "github::actions_workflow",
  "conditions": [
    "contains_value(path(resource, \"content\"), \"pull_request_target\")",
    "contains_value(path(resource, \"content\"), \"secrets.\")"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "devsecops",
    "github-actions",
    "supply-chain",
    "cicd-security"
  ],
  "remediation": "Review workflow for secret exposure. Use pull_request instead and avoid checkout of PR code with secrets.",
  "risk_categories": [
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "8.6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    }
  ]
}
