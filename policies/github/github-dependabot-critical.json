{
  "id": "github-dependabot-critical-alert",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GitHub Critical Dependabot Alert",
  "description": "Repository has critical Dependabot security alert open for more than 7 days",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "github::repository_dependabot_alert",
  "conditions": [
    "cmp_eq(path(resource, \"severity\"), \"critical\")",
    "cmp_eq(path(resource, \"state\"), \"open\")",
    "cmp_gt(path(resource, \"created_at_days\"), 7)"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "devsecops",
    "dependencies",
    "supply-chain",
    "dependabot"
  ],
  "remediation": "Update the vulnerable dependency or apply the security patch provided by Dependabot."
}
