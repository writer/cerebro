{
  "id": "github-dependabot-high-alert",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GitHub High Dependabot Alert",
  "description": "Repository has high severity Dependabot security alert open for more than 14 days",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "github::repository_dependabot_alert",
  "conditions": [
    "cmp_eq(path(resource, \"severity\"), \"high\")",
    "cmp_eq(path(resource, \"state\"), \"open\")",
    "cmp_gt(path(resource, \"created_at_days\"), 14)"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "devsecops",
    "dependencies",
    "supply-chain",
    "dependabot"
  ],
  "remediation": "Update the vulnerable dependency to a patched version."
}
