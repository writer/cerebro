{
  "id": "github-org-workflow-permissions",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GitHub Organization Default Workflow Permissions",
  "description": "Organization allows repositories to have default write permissions for GitHub Actions workflows",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "github::organization",
  "conditions": [
    "cmp_eq(path(resource, \"actions_permissions.default_workflow_permissions\"), \"write\")",
    "cmp_eq(path(resource, \"actions_permissions.can_approve_pull_request_reviews\"), true)"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "github",
    "actions",
    "organization",
    "supply-chain"
  ],
  "remediation": "Set organization default workflow permissions to 'read'. Disable 'Allow GitHub Actions to create and approve pull requests'. Let repositories opt-in to write permissions explicitly.",
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-2",
        "AC-6"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "7.2"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "5",
        "6"
      ]
    }
  ]
}
