{
  "id": "github-vuln-medium",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GitHub Repo Medium Vulnerabilities Addressed",
  "description": "Ensures medium vulnerabilities identified by Dependabot/Code Scanning are addressed within SLA (30 days)",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "github_dependabot_alerts",
  "conditions": [
    "cmp_eq(path(resource, \"severity\"), \"moderate\")",
    "cmp_eq(path(resource, \"state\"), \"open\")",
    "cmp_lt(path(resource, \"created_at\"), \"NOW() - INTERVAL '30 days'\")"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "github",
    "dependabot",
    "vulnerability",
    "medium",
    "sla",
    "compliance"
  ],
  "remediation": "Update dependencies to address medium severity vulnerabilities within 30 days.",
  "risk_categories": [
    "VULNERABLE_CODE"
  ],
  "frameworks": [
    {
      "name": "SOC 2",
      "controls": [
        "CC7.1"
      ]
    },
    {
      "name": "PCI DSS v4.0",
      "controls": [
        "6.3.1"
      ]
    },
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "RA-5",
