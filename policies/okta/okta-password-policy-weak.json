{
  "id": "okta-password-policy-weak",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Okta Password Policy Does Not Meet Standards",
  "description": "Okta password policy does not enforce sufficient complexity requirements",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "okta::policy::password",
  "conditions": [
    "(cmp_lt(path(resource, \"settings.password.complexity.min_length\"), 12)) || (cmp_gt(path(resource, \"settings.password.age.max_age_days\"), 365)) || (cmp_gt(path(resource, \"settings.password.lockout.max_attempts\"), 10))"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "okta",
    "authentication",
    "password-policy",
    "cis"
  ],
  "remediation": "Update password policy: minimum 12 characters, lockout after 5-10 attempts, reasonable password age. Consider passwordless authentication with WebAuthn.",
  "risk_categories": [
    "IDENTITY_RISK"
  ],
