{
  "id": "okta-app-no-mfa",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Okta Application Without MFA Policy",
  "description": "Okta application does not have an authentication policy requiring MFA",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "okta::application",
  "conditions": [
    "!(list_value(path(resource, \"sign_on_policy.rules\")).exists(item, cmp_eq(path(item, \"actions.signon.factor_mode\"), \"MFA_REQUIRED\")))",
    "!(matches_value(path(resource, \"label\"), \".*(test|dev|sandbox).*\"))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "okta",
    "application",
    "mfa",
    "authentication"
  ],
  "remediation": "Create or update the application's sign-on policy to require MFA. Use Okta's authentication policies to enforce MFA for sensitive applications.",
  "risk_categories": [
    "IDENTITY_RISK"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-2",
        "IA-5"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "8.3",
        "8.4"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "6"
      ]
    }
  ]
}
