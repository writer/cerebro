{
  "id": "sentinelone-vuln-medium",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "SentinelOne Agent Medium Vulnerabilities Addressed",
  "description": "Ensures medium vulnerabilities detected by SentinelOne are addressed within SLA (30 days)",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "sentinelone_vulnerabilities",
  "conditions": [
    "cmp_eq(path(resource, \"severity\"), \"Medium\")",
    "cmp_eq(path(resource, \"status\"), \"open\")",
    "cmp_lt(path(resource, \"detected_at\"), \"NOW() - INTERVAL '30 days'\")"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "sentinelone",
    "endpoint",
    "vulnerability",
    "medium",
    "sla",
    "compliance"
  ],
  "remediation": "Patch or update affected software to address medium severity vulnerabilities within 30 days.",
  "risk_categories": [
    "VULNERABLE_WORKLOAD"
  ],
  "frameworks": [
