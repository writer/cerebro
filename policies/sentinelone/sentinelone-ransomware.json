  "action": "",
  "resource": "sentinelone::threat",
  "conditions": [
    "(matches_value(path(resource, \"threat_info.classification\"), \"(?i)ransom\")) || (contains_value(path(resource, \"indicators.categories\"), \"Ransomware\"))"
