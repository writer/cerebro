{
  "id": "azure-keyvault-key-expiry-set",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Azure Key Vault Key Expiry Set",
  "description": "Azure Key Vault keys should have expiration dates set",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "azure::keyvault::key",
  "conditions": [
    "cmp_eq(path(resource, \"attributes.expires\"), null)"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "cis-azure-8.1",
    "keyvault",
    "keys",
    "rotation"
  ],
  "remediation": "Set an expiration date on the key to enforce rotation.",
  "risk_categories": [
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "8.6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    }
  ]
}
