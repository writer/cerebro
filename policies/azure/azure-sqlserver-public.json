  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Azure SQL Server Allows All Azure IPs",
  "description": "Azure SQL Server firewall allows connections from all Azure services (0.0.0.0)",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "azure::sql::server",
  "conditions": [
    "list_value(path(resource, \"firewall_rules\")).exists(item, (cmp_eq(path(item, \"start_ip_address\"), \"0.0.0.0\")) \u0026\u0026 (cmp_eq(path(item, \"end_ip_address\"), \"0.0.0.0\")))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
