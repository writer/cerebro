{
  "id": "azure-keyvault-logging",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Key Vault Diagnostic Logging Disabled",
  "description": "Azure Key Vault does not have diagnostic logging enabled for audit events",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "azure::keyvault::vault",
  "conditions": [
    "!(contains_value(path(resource, \"diagnostic_settings.logs\"), \"category == 'AuditEvent' AND enabled == true\"))"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "azure",
    "keyvault",
    "logging",
    "audit",
    "cis-azure-5.1.5"
  ],
  "remediation": "Enable diagnostic settings with AuditEvent logs sent to Log Analytics workspace or storage account.",
  "risk_categories": [
    "MISCONFIGURATION"
  ],
