  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Azure AD User Without MFA",
  "description": "Azure AD user does not have multi-factor authentication methods registered",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "azure::ad::user",
  "conditions": [
    "cmp_eq(path(resource, \"account_enabled\"), true)",
