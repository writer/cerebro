{
  "id": "azure-vm-public-ip-rdp",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Azure VM Public IP with RDP Exposed",
  "description": "Azure VM has public IP with RDP port 3389 allowed from Any source in NSG",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "azure::compute::virtual_machine",
  "conditions": [
    "cmp_ne(path(resource, \"public_ip_address\"), null)",
    "cmp_eq(path(resource, \"network_security_group.rules.destination_port\"), \"3389\")",
    "cmp_eq(path(resource, \"network_security_group.rules.source_address_prefix\"), \"*\")",
    "cmp_eq(path(resource, \"network_security_group.rules.access\"), \"Allow\")"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "cis-azure-6.2",
    "exposure",
    "vm",
    "network",
    "rdp"
  ],
  "remediation": "Remove public IP or restrict NSG rules to specific IP ranges. Use Azure Bastion for secure access.",
  "risk_categories": [
    "EXTERNAL_EXPOSURE"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
