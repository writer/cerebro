  "last_modified": "0001-01-01T00:00:00Z",
  "name": "CosmosDB Public Network Access Enabled",
  "description": "Azure CosmosDB account allows access from public networks",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "azure::cosmosdb::account",
  "conditions": [
    "cmp_eq(path(resource, \"public_network_access\"), \"Enabled\")",
