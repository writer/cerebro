{
  "id": "ai-bias-testing",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "AI Model Bias Testing Performed",
  "description": "Ensures AI models are tested for bias and fairness before deployment (ISO 42001)",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "ai_models",
  "conditions": [
    "in_list(path(resource, \"model_type\"), [\"classification\",\"recommendation\",\"scoring\"])",
