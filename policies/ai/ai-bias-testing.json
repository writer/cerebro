  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "ai",
    "ml",
    "bias",
    "fairness",
    "iso42001"
  ],
  "remediation": "Perform bias testing on AI models that make decisions affecting individuals. Document testing methodology and results.",
  "frameworks": [
    {
      "name": "ISO 42001",
      "controls": [
        "6.1",
        "9.2"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC1.4"
      ]
    }
  ]
