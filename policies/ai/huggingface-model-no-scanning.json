{
  "id": "ml-model-untrusted-source",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "ML Model from Untrusted Source",
  "description": "ML model loaded from external source without security scanning",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "ml::model_artifact",
  "conditions": [
    "cmp_eq(path(resource, \"source_type\"), \"external\")",
    "cmp_ne(path(resource, \"security_scan_status\"), \"passed\")"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "ai",
    "model-security",
    "supply-chain",
    "malicious-model"
  ],
  "remediation": "Scan external models for malicious payloads before deployment.",
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "LATERAL_MOVEMENT"
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1190"
    }
  ]
}
