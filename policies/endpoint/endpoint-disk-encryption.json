{
  "id": "endpoint-disk-encryption",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Endpoint Disk Encryption Enabled",
  "description": "Corporate endpoints (laptops/desktops) should have full disk encryption enabled (FileVault on macOS, BitLocker on Windows)",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "mdm_devices",
  "conditions": [
    "cmp_ne(path(resource, \"disk_encryption_enabled\"), true)",
    "cmp_eq(path(resource, \"device_type\"), path(resource, \"WORKSTATION\"))"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "endpoint",
    "encryption",
    "disk-encryption",
    "data-protection"
  ],
  "remediation": "Enable full disk encryption on the device through MDM policy enforcement or manual configuration",
  "remediation_steps": [
    "Identify the device without disk encryption",
    "Contact the device owner",
    "For macOS: Enable FileVault via MDM or System Preferences",
    "For Windows: Enable BitLocker via MDM or Group Policy",
    "Verify encryption status after enabling",
    "Store recovery keys securely in MDM"
  ],
  "risk_categories": [
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "CIS Controls v8",
      "controls": [
        "3.6"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6.7"
      ]
    },
    {
