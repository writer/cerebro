{
  "id": "vm-empty-password",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Internal VM with a local user that has an empty password",
  "description": "A virtual machine has a local user account with an empty password",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "compute::instance",
  "conditions": [
    "list_value(path(resource, \"local_users\")).exists(item, cmp_eq(path(item, \"password_empty\"), true))"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "wiz",
    "compute",
    "password",
    "authentication"
  ],
  "control_id": "wc-id-388",
  "remediation": "Set strong passwords for all local users. Disable unused accounts. Consider using centralized authentication.",
