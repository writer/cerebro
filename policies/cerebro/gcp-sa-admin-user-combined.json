{
  "id": "gcp-sa-admin-user-combined",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "User account with both 'Service Account Admin' and 'Service Account User' roles assigned",
  "description": "A user can both create and impersonate service accounts, a dangerous privilege combination",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "gcp::iam::member",
  "conditions": [
    "list_value(path(resource, \"roles\")).exists(item, cmp_eq(path(item, \"name\"), \"roles/iam.serviceAccountAdmin\"))",
    "list_value(path(resource, \"roles\")).exists(item, cmp_eq(path(item, \"name\"), \"roles/iam.serviceAccountUser\"))"
  ],
  "condition_format": "cel",
  "severity": "high",
