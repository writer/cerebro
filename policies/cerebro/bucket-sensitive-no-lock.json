{
  "id": "bucket-sensitive-no-lock",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Bucket with sensitive data has object lock disabled",
  "description": "A bucket containing sensitive data does not have object lock enabled",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "storage::bucket",
  "conditions": [
    "cmp_eq(path(resource, \"has_sensitive_data\"), true)",
    "cmp_eq(path(resource, \"object_lock_enabled\"), false)"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "wiz",
    "storage",
    "sensitive-data",
    "object-lock"
  ],
  "control_id": "wc-id-2566",
  "remediation": "Enable S3 Object Lock to prevent deletion or modification of sensitive data.",
  "risk_categories": [
    "UNPROTECTED_DATA",
    "MISCONFIGURATION"
  ],
  "mitre_attack": [
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}
