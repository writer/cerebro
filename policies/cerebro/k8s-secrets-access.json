{
  "id": "k8s-secrets-access",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "User/service account with get/list/watch permissions on secrets in a Kubernetes cluster",
  "description": "An identity can read secrets across the Kubernetes cluster",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "k8s::cluster_role|k8s::role|k8s::rbac::risky_binding",
  "conditions": [
    "(contains_value(path(resource, \"risk_reasons\"), \"secret_access\")) || (list_value(path(resource, \"rules\")).exists(item, (contains_value(path(item, \"resources\"), \"secrets\")) \u0026\u0026 (list_value(path(item, \"verbs\")).exists(item, in_list(path(item, \"verb\"), [\"get\",\"list\",\"watch\"])))))"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "wiz",
    "kubernetes",
    "secrets",
    "rbac"
  ],
  "control_id": "wc-id-472",
  "remediation": "Restrict secrets access to specific namespaces. Use external secret managers when possible.",
  "risk_categories": [
    "UNPROTECTED_DATA",
    "IDENTITY_RISK"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "8.6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    }
  ]
}
