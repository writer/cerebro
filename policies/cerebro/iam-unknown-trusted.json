{
  "id": "iam-unknown-account-trusted",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Unknown AWS account with trusted access to IAM role",
  "description": "An IAM role's trust policy allows assumption by an AWS account that is not part of the known organization, potentially enabling unauthorized cross-account access",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::iam::role",
  "conditions": [
    "(contains_value(path(resource, \"assume_role_policy_document\"), \":root\")) \u0026\u0026 (!(contains_value(path(resource, \"assume_role_policy_document\"), \"aws:PrincipalOrgID\")))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "aws",
    "iam",
    "trust-policy",
    "cross-account",
    "security"
  ],
  "remediation": "1. Review the trust policy and verify the trusted account is legitimate. 2. Add aws:PrincipalOrgID condition to restrict to organization accounts. 3. Use external ID for third-party access. 4. Remove untrusted principals.",
  "risk_categories": [
    "UNPROTECTED_PRINCIPAL"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-2",
        "AC-6",
        "AC-17"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "5",
        "6"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Privilege Escalation",
      "technique": "T1078"
    },
    {
      "tactic": "Defense Evasion",
      "technique": "T1550"
    }
  ]
}
