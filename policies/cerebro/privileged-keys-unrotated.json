{
  "id": "privileged-keys-unrotated",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "User/service account with high privileges and active access keys that were used in the past 90 days but not rotated in the past year",
  "description": "A privileged account has active access keys that have not been rotated in over a year",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "iam::user|iam::service_account",
  "conditions": [
    "cmp_eq(path(resource, \"has_high_privilege\"), true)",
    "list_value(path(resource, \"access_keys\")).exists(item, (cmp_eq(path(item, \"status\"), \"Active\")) \u0026\u0026 (cmp_lt(path(item, \"last_used_days_ago\"), 90)) \u0026\u0026 (cmp_gt(path(item, \"created_days_ago\"), 365)))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "wiz",
    "identity",
    "access-keys",
    "privileged",
    "rotation"
  ],
  "control_id": "wc-id-2222",
  "remediation": "Rotate access keys immediately. Implement automated key rotation.",
  "risk_categories": [
    "IDENTITY_RISK",
    "PRIVILEGE_ESCALATION"
  ],
  "frameworks": [
    {
