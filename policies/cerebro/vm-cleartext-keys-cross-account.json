{
  "id": "vm-cleartext-keys-cross-account",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "VM/serverless with cleartext cloud keys granting permission to access resources in external subscriptions",
  "description": "A compute resource contains cleartext cloud keys that grant access to resources in other cloud accounts or subscriptions",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "compute::instance|serverless::function",
  "conditions": [
    "list_value(path(resource, \"secrets\")).exists(item, (cmp_eq(path(item, \"type\"), \"cloud_key\")) \u0026\u0026 (cmp_eq(path(item, \"cleartext\"), true)) \u0026\u0026 (cmp_eq(path(item, \"cross_account_access\"), true)))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "wiz",
    "secrets",
    "cleartext-keys",
    "cross-account"
  ],
  "control_id": "wc-id-259",
  "remediation": "Remove cleartext keys. Use cross-account IAM roles with proper trust relationships. Implement proper secrets management.",
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "UNPROTECTED_DATA",
    "LATERAL_MOVEMENT"
  ],
