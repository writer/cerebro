{
  "id": "container-openssl-vuln",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Internal container has an image vulnerable to CVE-2022-3602 or CVE-2022-3786 (OpenSSL vulnerability)",
  "description": "A container is running an image vulnerable to OpenSSL vulnerabilities",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "container::image",
  "conditions": [
    "(cmp_eq(path(resource, \"has_openssl_vulnerability\"), true)) || (contains_value(path(resource, \"vulnerabilities\"), \"CVE-2022-3602\")) || (contains_value(path(resource, \"vulnerabilities\"), \"CVE-2022-3786\"))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "wiz",
    "container",
    "vulnerability",
    "openssl"
  ],
  "control_id": "wc-id-1098",
  "remediation": "Rebuild container image with OpenSSL 3.0.7 or later.",
  "risk_categories": [
    "VULNERABILITY"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
