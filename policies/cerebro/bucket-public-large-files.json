{
  "id": "bucket-public-large-files",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Publicly readable bucket contains large log and data files",
  "description": "A public bucket contains large files that may contain sensitive information",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "storage::bucket|storage::blob_container",
  "conditions": [
    "cmp_eq(path(resource, \"is_public\"), true)",
    "list_value(path(resource, \"objects\")).exists(item, (cmp_gt(path(item, \"size_mb\"), 100)) \u0026\u0026 (in_list(path(item, \"file_type\"), [\"log\",\"csv\",\"json\",\"parquet\"])))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "wiz",
    "storage",
    "public-exposure",
    "data-files"
  ],
  "control_id": "wc-id-2559",
  "remediation": "Remove public access. Review large files for sensitive content before any exposure.",
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-3",
        "SC-7"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "1.3",
        "1.4"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "12",
        "13"
      ]
    }
  ],
  "mitre_attack": [
