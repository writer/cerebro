{
  "id": "bucket-keys-excessive-access",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Bucket with cleartext cloud keys allowing high privileges can be accessed by an account with excessive data access",
  "description": "A bucket with privileged keys can be accessed by an overly permissive account",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "storage::bucket|storage::blob_container",
  "conditions": [
    "list_value(path(resource, \"secrets\")).exists(item, (cmp_eq(path(item, \"type\"), \"cloud_key\")) \u0026\u0026 (cmp_eq(path(item, \"cleartext\"), true)) \u0026\u0026 (cmp_eq(path(item, \"grants_high_privilege\"), true)))",
    "list_value(path(resource, \"iam_policy.principals\")).exists(item, cmp_eq(path(item, \"has_excessive_data_access\"), true))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "wiz",
    "storage",
    "secrets",
    "excessive-access"
  ],
  "control_id": "wc-id-1340",
  "remediation": "Remove cleartext keys. Restrict bucket access to minimum required principals.",
  "risk_categories": [
    "UNPROTECTED_DATA",
    "IDENTITY_RISK",
    "PRIVILEGE_ESCALATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-2",
        "AC-6",
        "IA-5",
        "SC-12"
      ]
    },
