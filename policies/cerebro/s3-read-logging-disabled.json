{
  "id": "s3-read-logging-disabled",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "S3 Bucket with object-level read data events logging disabled",
  "description": "An S3 bucket does not have CloudTrail data event logging enabled for read operations",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::s3::bucket",
  "conditions": [
    "cmp_eq(path(resource, \"cloudtrail_data_events.read_enabled\"), false)"
  ],
  "condition_format": "cel",
  "severity": "low",
  "tags": [
    "wiz",
    "aws",
    "s3",
    "logging",
    "cloudtrail"
  ],
  "control_id": "wc-id-943",
  "remediation": "Enable CloudTrail data events for read operations on sensitive buckets.",
