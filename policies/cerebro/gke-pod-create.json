{
  "id": "gke-pod-create",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GKE user/service accounts with the privileges to create pods",
  "description": "An identity can create pods in GKE, which could be used for privilege escalation",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "gcp::gke::cluster_role|gcp::gke::role|k8s::rbac::risky_binding",
  "conditions": [
    "(contains_value(path(resource, \"risk_reasons\"), \"pod_create_access\")) || (list_value(path(resource, \"rules\")).exists(item, (contains_value(path(item, \"resources\"), \"pods\")) \u0026\u0026 (contains_value(path(item, \"verbs\"), \"create\"))))"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "wiz",
    "gke",
    "kubernetes",
    "rbac",
    "pods"
  ],
  "control_id": "wc-id-448",
  "remediation": "Restrict pod creation privileges. Implement admission controllers to validate pod specs.",
  "risk_categories": [
    "IDENTITY_RISK",
    "PRIVILEGE_ESCALATION"
  ],
