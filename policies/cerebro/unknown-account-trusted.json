{
  "id": "unknown-account-trusted",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Unknown AWS account with trusted access to non-admin IAM role",
  "description": "An unknown AWS account has trust relationship to assume a role",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::iam::role",
  "conditions": [
    "list_value(path(resource, \"trust_policy.principals\")).exists(item, (cmp_eq(path(item, \"type\"), \"AWS\")) \u0026\u0026 (!(in_list(path(item, \"account_id\"), [\"known_accounts\"]))))"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "wiz",
    "aws",
    "identity",
    "trust",
    "cross-account"
  ],
  "control_id": "wc-id-2082",
  "remediation": "Review and validate all cross-account trust relationships. Remove unknown accounts.",
  "risk_categories": [
    "IDENTITY_RISK",
    "LATERAL_MOVEMENT",
    "PRIVILEGE_ESCALATION"
  ],
  "mitre_attack": [
    {
      "tactic": "Persistence",
      "technique": "T1098"
    },
    {
      "tactic": "Lateral Movement",
      "technique": "T1021"
    }
  ]
}
