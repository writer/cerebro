{
  "id": "exposed-saas-api-token",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Validated exposure of SaaS API token",
  "description": "A SaaS API token has been found exposed in a resource configuration, environment variable, or code, potentially allowing unauthorized access to external services",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "gcp::cloudrun::revision",
  "conditions": [
    "(contains_value(path(resource, \"containers\"), \"API_KEY\")) || (contains_value(path(resource, \"containers\"), \"api_key\")) || (contains_value(path(resource, \"containers\"), \"SECRET\")) || (contains_value(path(resource, \"containers\"), \"TOKEN\"))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "gcp",
    "secrets",
    "api-token",
    "exposure",
    "security"
  ],
  "remediation": "1. Immediately rotate the exposed API token. 2. Move secrets to Secret Manager. 3. Use workload identity for authentication where possible. 4. Audit access logs for unauthorized use.",
  "risk_categories": [
    "INSECURE_USE_OF_SECRETS"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-5",
        "SC-12",
        "SC-28"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "3",
        "16"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    }
  ]
}
