  "last_modified": "0001-01-01T00:00:00Z",
  "name": "User account with excessive admin privileges",
  "description": "A user account has more admin privileges than necessary for their role",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "iam::user",
  "conditions": [
