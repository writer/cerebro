{
  "id": "user-data-access-unused-password",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "User account with data access to sensitive data and an unused password",
  "description": "A user with access to sensitive data has an unused password, suggesting the account may be dormant",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "iam::user",
  "conditions": [
    "cmp_eq(path(resource, \"has_sensitive_data_access\"), true)",
    "(cmp_eq(path(resource, \"password_last_used\"), null)) || (cmp_gt(path(resource, \"password_last_used_days_ago\"), 365))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "wiz",
    "identity",
    "dormant",
    "data-access",
    "unused-password"
  ],
  "control_id": "wc-id-1373",
  "remediation": "Review and disable unused accounts with data access. Implement regular access certification.",
  "risk_categories": [
    "UNPROTECTED_DATA",
    "IDENTITY_RISK"
  ],
  "frameworks": [
