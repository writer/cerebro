      "controls": [
        "7.2"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "5",
        "6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Privilege Escalation",
      "technique": "T1078"
    }
  ]
}
