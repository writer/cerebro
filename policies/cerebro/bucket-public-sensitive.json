{
  "id": "bucket-public-sensitive",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Publicly readable bucket contains sensitive data",
  "description": "Storage bucket allows anonymous read access (allUsers) and may contain sensitive data, creating a direct data breach risk",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "gcp::storage::bucket",
  "conditions": [
    "contains_value(path(resource, \"iam_policy\"), \"allUsers\")"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "gcp",
    "storage",
    "public-access",
    "data-exposure",
    "toxic-combination",
    "security"
  ],
  "control_id": "wc-id-1264",
  "remediation": "1. Remove public access by removing allUsers and allAuthenticatedUsers from IAM bindings. 2. Implement proper access controls using IAM. 3. Enable uniform bucket-level access. 4. Review bucket contents for sensitive data.",
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "EXTERNAL_ATTACK_SURFACE",
    "UNPROTECTED_DATA"
  ],
