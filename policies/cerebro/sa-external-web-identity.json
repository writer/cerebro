{
  "id": "sa-external-web-identity",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Service account with high privileges can be assumed by an external web identity",
  "description": "A highly privileged service account can be assumed by an external web identity provider",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "iam::service_account|iam::role",
  "conditions": [
    "cmp_eq(path(resource, \"has_high_privilege\"), true)",
    "cmp_eq(path(resource, \"trust_policy.allows_external_web_identity\"), true)"
  ],
  "condition_format": "cel",
  "severity": "high",
