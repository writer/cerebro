{
  "id": "bucket-public-low-exposure",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Publicly readable non-empty bucket with low exposure level",
  "description": "A non-empty bucket is publicly readable even with low exposure level",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "storage::bucket|storage::blob_container",
  "conditions": [
    "cmp_eq(path(resource, \"is_public\"), true)",
    "cmp_gt(path(resource, \"object_count\"), 0)"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "wiz",
    "storage",
    "public-exposure"
  ],
  "control_id": "wc-id-2836",
  "remediation": "Review if public access is required. Remove public access if not necessary for business operations.",
  "risk_categories": [
    "EXTERNAL_EXPOSURE"
  ],
