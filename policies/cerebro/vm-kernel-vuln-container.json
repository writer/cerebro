{
  "id": "vm-kernel-vuln-container",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "VM with kernel vulnerabilities is running a container",
  "description": "A VM with kernel vulnerabilities is running containers, risking container escape",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "compute::instance",
  "conditions": [
    "list_value(path(resource, \"vulnerabilities\")).exists(item, (cmp_eq(path(item, \"component\"), \"kernel\")) \u0026\u0026 (in_list(path(item, \"severity\"), [\"CRITICAL\",\"HIGH\"])))",
    "cmp_gt(path(resource, \"running_containers_count\"), 0)"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "wiz",
    "compute",
    "vulnerability",
    "kernel",
    "container"
  ],
  "control_id": "wc-id-183",
  "remediation": "Patch kernel vulnerabilities. Consider migrating containers to patched nodes.",
  "risk_categories": [
    "VULNERABILITY"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "RA-5",
        "SI-2"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "6.3",
        "11.3"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "7"
      ]
    }
  ]
}
