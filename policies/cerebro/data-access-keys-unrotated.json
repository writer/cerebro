{
  "id": "data-access-keys-unrotated",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "User/service account with access to sensitive data and active access keys unrotated in the past year",
  "description": "An account with access to sensitive data has access keys that have not been rotated in over a year",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "iam::user|iam::service_account",
  "conditions": [
    "cmp_eq(path(resource, \"has_sensitive_data_access\"), true)",
    "list_value(path(resource, \"access_keys\")).exists(item, (cmp_eq(path(item, \"status\"), \"Active\")) \u0026\u0026 (cmp_gt(path(item, \"created_days_ago\"), 365)))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "wiz",
    "identity",
    "access-keys",
    "data-access",
    "rotation"
  ],
  "control_id": "wc-id-2225",
  "remediation": "Rotate access keys. Implement key rotation policy for accounts with data access.",
  "risk_categories": [
    "UNPROTECTED_DATA",
    "IDENTITY_RISK"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-2",
        "AC-6",
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "7.2",
        "3.5",
        "8.6"
      ]
    },
    {
