      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "5",
        "6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Persistence",
      "technique": "T1098"
    },
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    },
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}
