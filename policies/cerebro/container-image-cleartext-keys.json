{
  "id": "container-image-cleartext-keys",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Container image with cleartext cloud keys granting high privileges",
  "description": "A container image contains cleartext cloud keys with high privileges",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "container::image",
  "conditions": [
    "(cmp_eq(path(resource, \"has_high_privilege_cloud_keys\"), true)) || (list_value(path(resource, \"secrets\")).exists(item, (cmp_eq(path(item, \"type\"), \"cloud_key\")) \u0026\u0026 (cmp_eq(path(item, \"cleartext\"), true)) \u0026\u0026 (cmp_eq(path(item, \"grants_high_privilege\"), true))))"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "wiz",
    "container",
    "secrets",
    "cleartext-keys",
    "privileged"
  ],
  "control_id": "wc-id-1026",
  "remediation": "Rebuild image without embedded keys. Use secret injection at runtime. Rotate exposed keys.",
  "risk_categories": [
    "UNPROTECTED_DATA",
    "IDENTITY_RISK",
    "PRIVILEGE_ESCALATION"
  ],
  "frameworks": [
