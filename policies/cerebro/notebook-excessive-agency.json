{
  "id": "notebook-excessive-agency",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Notebook with excessive agency",
  "description": "A notebook has excessive permissions that could lead to unintended resource access",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "ai::notebook",
  "conditions": [
    "(cmp_eq(path(resource, \"execution_role.has_admin_role\"), true)) || (cmp_eq(path(resource, \"can_access_production_data\"), true))"
  ],
  "condition_format": "cel",
  "severity": "high",
