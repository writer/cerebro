{
  "id": "sa-lateral-admin",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Service account with lateral movement to admin in another account",
  "description": "A service account has an attack path that leads to admin privileges in another cloud account",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "iam::service_account",
  "conditions": [
    "list_value(path(resource, \"attack_paths\")).exists(item, (cmp_eq(path(item, \"target.is_admin\"), true)) \u0026\u0026 (cmp_eq(path(item, \"target.is_cross_account\"), true)))"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
