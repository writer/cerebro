{
  "id": "serverless-unauthenticated-invocation",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Publicly exposed serverless with high privileges can be invoked by unauthenticated users",
  "description": "Cloud Function or Cloud Run service is publicly accessible without authentication and runs with high privileges, allowing anyone to invoke it and potentially abuse its permissions",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "gcp::cloudfunctions::function",
  "conditions": [
    "(cmp_eq(path(resource, \"service_config.ingress_settings\"), \"ALLOW_ALL\")) || (cmp_eq(path(resource, \"service_config.ingress_settings\"), \"INGRESS_SETTINGS_UNSPECIFIED\"))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "gcp",
    "cloudfunctions",
    "serverless",
    "authentication",
    "public-access",
    "security"
  ],
  "remediation": "1. Enable IAM-based authentication for the function. 2. Restrict ingress to internal traffic only. 3. Create dedicated service account with minimal permissions. 4. Use VPC connectors for private access.",
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "UNPROTECTED_PRINCIPAL"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-3",
        "AC-6",
        "SC-7"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "5",
        "6",
        "12"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1190"
    },
    {
      "tactic": "Execution",
      "technique": "T1648"
    }
  ]
}
