{
  "id": "container-cleartext-cloud-keys",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Container image with cleartext cloud keys granting high privileges",
  "description": "A container image contains hardcoded cloud credentials (AWS access keys, GCP service account keys) that grant high privileges, enabling lateral movement if the container is compromised",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::ecs::task_definition",
  "conditions": [
    "(contains_value(path(resource, \"container_definitions\"), \"AWS_ACCESS_KEY\")) || (contains_value(path(resource, \"container_definitions\"), \"AWS_SECRET\")) || (contains_value(path(resource, \"container_definitions\"), \"GOOGLE_APPLICATION_CREDENTIALS\"))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "aws",
    "ecs",
    "container",
    "secrets",
    "credentials",
    "security"
  ],
  "remediation": "1. Remove hardcoded credentials from container images. 2. Use IAM roles for tasks (ECS) or workload identity (GKE). 3. Rotate any exposed credentials immediately. 4. Scan images for secrets before deployment.",
  "risk_categories": [
    "INSECURE_USE_OF_SECRETS",
    "UNPROTECTED_PRINCIPAL"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-5",
        "SC-12",
        "SC-28"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "3",
        "16"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    },
    {
      "tactic": "Lateral Movement",
      "technique": "T1550"
    }
  ]
}
