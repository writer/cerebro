{
  "id": "vm-ssh-private-keys",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "VM/serverless with cleartext SSH private keys that can be used to access other resources",
  "description": "A compute resource contains SSH private keys that can be used to access other resources",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "compute::instance|serverless::function",
  "conditions": [
    "list_value(path(resource, \"secrets\")).exists(item, (cmp_eq(path(item, \"type\"), \"ssh_private_key\")) \u0026\u0026 (cmp_eq(path(item, \"cleartext\"), true)) \u0026\u0026 (cmp_eq(path(item, \"can_access_other_resources\"), true)))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "wiz",
    "secrets",
    "ssh-keys",
    "lateral-movement"
  ],
  "control_id": "wc-id-343",
  "remediation": "Remove SSH private keys from the resource. Use SSH certificate-based authentication or IAM-based access. Rotate compromised keys.",
  "risk_categories": [
    "UNPROTECTED_DATA",
    "LATERAL_MOVEMENT"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-2",
        "AC-6",
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "7.2",
        "3.5",
        "8.6"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "5",
        "6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    },
    {
      "tactic": "Lateral Movement",
      "technique": "T1021"
    }
  ]
}
