{
  "id": "public-resource-cross-account-keys",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Publicly exposed resource with cleartext cloud keys granting permission to access resources in other subscriptions",
  "description": "A public resource contains cross-account access keys",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "*",
  "conditions": [
    "cmp_eq(path(resource, \"is_public\"), true)",
    "list_value(path(resource, \"secrets\")).exists(item, (cmp_eq(path(item, \"type\"), \"cloud_key\")) \u0026\u0026 (cmp_eq(path(item, \"cleartext\"), true)) \u0026\u0026 (cmp_eq(path(item, \"cross_account_access\"), true)))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "wiz",
    "secrets",
    "cross-account",
    "public-exposure"
  ],
  "control_id": "wc-id-392",
  "remediation": "Remove cleartext cross-account keys. Use IAM roles for cross-account access.",
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "UNPROTECTED_DATA",
    "LATERAL_MOVEMENT"
  ],
  "frameworks": [
