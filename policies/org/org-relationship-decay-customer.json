{
  "id": "org-relationship-decay-customer",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Customer Relationship Weakening",
  "description": "Primary contact interaction with customer has decayed below threshold before renewal.",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "org::customer_relationship",
  "conditions": [
    "cmp_lt(path(resource, \"relationship_strength\"), 0.3)",
    "cmp_gt(path(resource, \"previous_strength\"), 0.7)",
    "cmp_lt(path(resource, \"renewal_days\"), 90)"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "org-topology",
    "customer-health",
    "churn-risk"
  ],
  "remediation": "Escalate account engagement and assign backup contacts before renewal.",
  "risk_categories": [
    "CUSTOMER_HEALTH_RISK",
    "CHURN_RISK"
  ]
}
