{
  "id": "org-customer-touchpoints-low",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Customer Touchpoint Coverage Too Thin",
  "description": "Customer relationship has fewer than two active touchpoints.",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "org::customer_relationship",
  "conditions": [
    "cmp_lt(path(resource, \"touchpoint_count\"), 2)",
    "cmp_lt(path(resource, \"renewal_days\"), 120)"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "org-topology",
    "customer-health",
    "coverage"
  ],
  "remediation": "Add at least one additional owner and auto-escalate to the account owner for coverage recovery.",
  "risk_categories": [
    "CUSTOMER_HEALTH_RISK",
    "RESILIENCE_RISK"
  ]
}
