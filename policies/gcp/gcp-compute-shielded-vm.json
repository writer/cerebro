{
  "id": "gcp-compute-shielded-vm",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GCP Compute Shielded VM",
  "description": "Compute instances should use shielded VM features",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "gcp::compute::instance",
  "conditions": [
    "cmp_ne(path(resource, \"shielded_instance_config.enable_secure_boot\"), true)",
    "cmp_ne(path(resource, \"shielded_instance_config.enable_vtpm\"), true)"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "cis-gcp-4.8",
    "compute",
    "security",
    "shielded-vm"
  ],
  "remediation": "Enable Secure Boot, vTPM, and Integrity Monitoring on the instance.",
  "risk_categories": [
    "MISCONFIGURATION"
  ]
}
