{
  "id": "gcp-cloudrun-default-service-account",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Cloud Run Service Using Default Compute Service Account",
  "description": "Cloud Run services using the default compute service account have excessive privileges and pose a security risk",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "gcp::cloudrun::revision",
  "conditions": [
    "contains_value(path(resource, \"service_account\"), \"compute@developer.gserviceaccount.com\")"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "gcp",
    "cloudrun",
    "serverless",
    "iam",
    "least-privilege"
  ],
  "remediation": "Create a dedicated service account with minimal required permissions for the Cloud Run service. Update the service to use the dedicated service account instead of the default compute service account.",
  "risk_categories": [
    "UNPROTECTED_PRINCIPAL",
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-6",
        "AC-2"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "5",
        "6"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Privilege Escalation",
      "technique": "T1078"
    }
  ]
}
