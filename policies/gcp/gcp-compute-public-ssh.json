{
  "id": "gcp-compute-public-ssh",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GCP Instance Public IP with SSH Exposed",
  "description": "GCP Compute instance has external IP with firewall allowing SSH from 0.0.0.0/0",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "gcp::compute::instance",
  "conditions": [
    "cmp_ne(path(resource, \"network_interfaces.access_configs\"), null)",
    "contains_value(path(resource, \"firewall_rules.allowed.ports\"), \"22\")",
    "contains_value(path(resource, \"firewall_rules.source_ranges\"), \"0.0.0.0/0\")"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "cis-gcp-3.6",
    "exposure",
    "compute",
    "network",
    "ssh"
  ],
  "remediation": "Remove external IP or restrict firewall rules. Use IAP for TCP forwarding for secure access.",
  "risk_categories": [
    "EXTERNAL_EXPOSURE"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-3",
        "SC-7"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "1.3",
        "1.4"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "12",
