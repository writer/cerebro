{
  "id": "gcp-container-vuln-low",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GCP Container Low Vulnerabilities Addressed",
  "description": "Ensures low vulnerabilities in GCP container images are tracked and addressed within SLA (90 days)",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "gcp_container_vulnerabilities",
  "conditions": [
    "cmp_eq(path(resource, \"severity\"), \"LOW\")",
    "cmp_eq(path(resource, \"state\"), \"ACTIVE\")",
    "cmp_lt(path(resource, \"discovered_at\"), \"NOW() - INTERVAL '90 days'\")"
  ],
  "condition_format": "cel",
  "severity": "low",
  "tags": [
    "gcp",
    "container",
    "vulnerability",
    "low",
    "sla",
    "compliance"
  ],
  "remediation": "Address low vulnerabilities during regular maintenance cycles within 90 days.",
  "risk_categories": [
    "VULNERABLE_WORKLOAD"
  ],
  "frameworks": [
    {
      "name": "SOC 2",
      "controls": [
        "CC7.1"
      ]
    },
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "RA-5"
      ]
    }
  ]
}
