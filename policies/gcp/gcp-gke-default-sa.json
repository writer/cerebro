{
  "id": "gcp-gke-default-sa",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GKE Node Pool Using Default Service Account",
  "description": "GKE node pool is using the Compute Engine default service account instead of a dedicated service account",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "gcp::container::node_pool",
  "conditions": [
    "(cmp_eq(path(resource, \"config.service_account\"), \"default\")) || (ends_with_value(path(resource, \"config.service_account\"), \"-compute@developer.gserviceaccount.com\"))"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "gcp",
    "gke",
    "kubernetes",
    "least-privilege",
    "cis-gcp-7.17"
  ],
  "remediation": "Create a dedicated service account with minimal permissions for the node pool. Update the node pool configuration.",
  "risk_categories": [
    "PRIVILEGE_ESCALATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-2",
        "AC-6"
      ]
    },
