  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GCP Service Account No Admin Privileges",
  "description": "Service accounts should not have Owner or Editor roles at project level",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "gcp::iam::service_account",
  "conditions": [
    "(contains_value(path(resource, \"roles\"), \"roles/owner\")) || (contains_value(path(resource, \"roles\"), \"roles/editor\"))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "cis-gcp-1.5",
    "iam",
    "service-account",
    "least-privilege"
  ],
  "remediation": "Replace Owner/Editor with more specific roles following least privilege principle.",
