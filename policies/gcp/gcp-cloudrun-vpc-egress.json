{
  "id": "gcp-cloudrun-no-vpc-connector",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Cloud Run Service Without VPC Connector",
  "description": "Cloud Run service is not configured with a VPC connector, allowing direct egress to the public internet",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "gcp::cloudrun::revision",
  "conditions": [
    "(!exists_path(resource, \"vpc_access\")) || (cmp_eq(path(resource, \"vpc_access.connector\"), \"\"))"
  ],
  "condition_format": "cel",
  "severity": "low",
  "tags": [
    "gcp",
    "cloudrun",
    "serverless",
    "vpc",
    "network"
  ],
  "remediation": "Configure a VPC connector for the Cloud Run service to control egress traffic and enable access to VPC resources.",
  "risk_categories": [
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "SC-7"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "12"
      ]
    }
  ]
}
