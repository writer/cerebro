{
  "id": "gcp-container-vuln-high",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GCP Container High Vulnerabilities Addressed",
  "description": "Ensures high vulnerabilities in GCP container images are remediated within SLA (14 days)",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "gcp_container_vulnerabilities",
  "conditions": [
    "cmp_eq(path(resource, \"severity\"), \"HIGH\")",
    "cmp_eq(path(resource, \"state\"), \"ACTIVE\")",
    "cmp_lt(path(resource, \"discovered_at\"), \"NOW() - INTERVAL '14 days'\")"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "gcp",
    "container",
    "vulnerability",
    "high",
    "sla",
    "compliance"
  ],
  "remediation": "Update container images to address high vulnerabilities within 14 days of discovery.",
  "risk_categories": [
    "VULNERABLE_WORKLOAD"
  ],
  "frameworks": [
    {
      "name": "SOC 2",
      "controls": [
        "CC7.1"
      ]
    },
    {
      "name": "PCI DSS v4.0",
      "controls": [
        "6.3.1"
      ]
    },
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "RA-5",
        "SI-2"
      ]
    }
  ]
}
