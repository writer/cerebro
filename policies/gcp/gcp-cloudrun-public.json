{
  "id": "gcp-cloudrun-public-ingress",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Cloud Run Service Allows Public Internet Access",
  "description": "Cloud Run service is configured to allow ingress from all sources including the public internet",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "gcp::cloudrun::service",
  "conditions": [
    "cmp_eq(path(resource, \"ingress\"), \"INGRESS_TRAFFIC_ALL\")"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "gcp",
    "cloudrun",
    "serverless",
    "exposure",
    "network"
  ],
  "remediation": "Configure ingress settings to restrict traffic to internal sources only or use IAP/Cloud Armor for authentication. Set ingress to 'INGRESS_TRAFFIC_INTERNAL_ONLY' or 'INGRESS_TRAFFIC_INTERNAL_LOAD_BALANCER'.",
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "MISCONFIGURATION"
  ],
