  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GCP Storage No Public allUsers Access",
  "description": "Cloud Storage buckets should not grant access to allUsers (public)",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "gcp::storage::bucket",
  "conditions": [
    "contains_value(path(resource, \"iam_policy.bindings.members\"), \"allUsers\")"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
