{
  "id": "gcp-sa-admin-privileges",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GCP Service Account with Admin Privileges",
  "description": "Service account has been granted organization or project admin roles",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "gcp::iam::service_account",
  "conditions": [
    "list_value(path(resource, \"iam_bindings\")).exists(item, in_list(path(item, \"role\"), [\"roles/owner\",\"roles/editor\",\"roles/resourcemanager.organizationAdmin\",\"roles/resourcemanager.projectIamAdmin\"]))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "gcp",
    "iam",
    "service-account",
    "least-privilege",
    "cis-gcp-1.5"
  ],
  "remediation": "Remove admin roles from service accounts. Create custom roles with minimal required permissions. Use Workload Identity Federation where possible.",
  "risk_categories": [
    "IDENTITY_RISK",
    "PRIVILEGE_ESCALATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-2",
        "AC-6"
      ]
    },
    {
