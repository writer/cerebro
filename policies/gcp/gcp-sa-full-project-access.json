{
  "id": "gcp-sa-no-full-project-access",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "GCP Service Account No Full Access Scopes",
  "description": "Service account should not have cloud-platform (full access) scope on compute instances",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "gcp::compute::instance",
  "conditions": [
    "contains_value(path(resource, \"service_accounts.scopes\"), \"https://www.googleapis.com/auth/cloud-platform\")"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "cis-gcp-4.2",
    "iam",
    "service-account",
    "least-privilege"
  ],
  "remediation": "Replace cloud-platform scope with specific, minimal scopes required by the workload.",
