{
  "id": "telemetry-repo-secret-key",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Repository Contains Hardcoded Secrets",
  "description": "Source code repository contains hardcoded secrets, API keys, or credentials detected by secret scanning",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "telemetry::secret_scan::finding",
  "conditions": [
    "cmp_eq(path(resource, \"status\"), \"open\")",
    "in_list(path(resource, \"secret_type\"), [\"aws_access_key\",\"github_token\",\"private_key\",\"generic_password\",\"api_key\",\"database_connection_string\"])"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "telemetry",
    "secrets",
    "code-scanning",
    "supply-chain",
    "cwe-798"
  ],
  "remediation": "Rotate the exposed credential immediately. Remove secret from repository history using git filter-branch or BFG. Store secrets in a secrets manager. Enable pre-commit hooks to prevent future leaks.",
  "risk_categories": [
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "8.6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1078"
    },
    {
      "tactic": "Execution",
      "technique": "T1059"
    },
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    }
  ]
}
