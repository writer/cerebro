{
  "id": "aws-ecr-scan-on-push",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "ECR Scan on Push Enabled",
  "description": "ECR repositories should have scan on push enabled to detect vulnerabilities",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::ecr::repository",
  "conditions": [
    "cmp_ne(path(resource, \"image_scanning_configuration.scan_on_push\"), true)"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "ecr",
    "container",
    "vulnerability",
    "scanning"
  ],
  "remediation": "Enable scan on push in the ECR repository image scanning configuration.",
  "risk_categories": [
    "MISCONFIGURATION",
    "VULNERABILITY"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "RA-5",
        "SI-2"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "6.3",
        "11.3"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "7"
      ]
    }
  ]
}
