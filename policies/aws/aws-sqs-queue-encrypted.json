{
  "id": "aws-sqs-queue-encrypted",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "SQS Queue Encrypted",
  "description": "SQS queues should be encrypted with KMS",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::sqs::queue",
  "conditions": [
    "cmp_eq(path(resource, \"kms_master_key_id\"), null)"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "sqs",
    "encryption",
    "messaging"
  ],
  "remediation": "Enable server-side encryption for the SQS queue using a KMS key.",
  "risk_categories": [
    "UNPROTECTED_DATA",
    "MISCONFIGURATION"
  ],
  "frameworks": [
