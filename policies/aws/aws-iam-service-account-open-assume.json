{
  "id": "aws-iam-service-account-open-assume",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "IAM Role with Overly Permissive Trust Policy",
  "description": "IAM role trust policy allows any AWS service or account to assume the role",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::iam::role",
  "conditions": [
    "list_value(path(resource, \"assume_role_policy.Statement\")).exists(item, (cmp_eq(path(item, \"Principal\"), \"*\")) || (cmp_eq(path(item, \"Principal.AWS\"), \"*\")) || (cmp_eq(path(item, \"Principal.Service\"), \"*\")))"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "aws",
    "iam",
    "trust-policy",
    "privilege-escalation"
  ],
  "remediation": "Restrict trust policy to specific AWS accounts, services, or principals. Add external ID conditions for cross-account access. Use least privilege for trusted entities.",
  "risk_categories": [
    "IDENTITY_RISK",
    "LATERAL_MOVEMENT",
    "PRIVILEGE_ESCALATION"
  ],
