{
  "id": "aws-cloudfront-http",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "CloudFront Distribution Allows HTTP",
  "description": "CloudFront distribution allows unencrypted HTTP traffic instead of requiring HTTPS",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::cloudfront::distribution",
  "conditions": [
    "(cmp_ne(path(resource, \"viewer_protocol_policy\"), \"https-only\")) \u0026\u0026 (cmp_ne(path(resource, \"viewer_protocol_policy\"), \"redirect-to-https\"))"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "aws",
    "cloudfront",
    "encryption",
    "transport-security"
  ],
  "remediation": "Update the distribution's viewer protocol policy to 'redirect-to-https' or 'https-only'. Ensure a valid SSL certificate is configured.",
  "risk_categories": [
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "SC-12",
        "SC-13",
        "SC-28"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "4.2"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "3"
      ]
    }
  ]
}
