{
  "id": "aws-s3-bucket-ssl-only",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "S3 Bucket Requires SSL",
  "description": "S3 bucket policy should enforce SSL/TLS for all requests",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::s3::bucket",
  "conditions": [
    "cmp_ne(path(resource, \"policy_requires_ssl\"), true)"
