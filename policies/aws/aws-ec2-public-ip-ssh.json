{
  "id": "aws-ec2-public-ip-ssh",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "EC2 Public IP with SSH Exposed",
  "description": "EC2 instance has public IP with SSH port 22 open to the internet (0.0.0.0/0)",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::ec2::instance",
  "conditions": [
    "cmp_ne(path(resource, \"public_ip_address\"), null)",
    "cmp_le(path(resource, \"security_groups.ingress.from_port\"), 22)",
    "cmp_ge(path(resource, \"security_groups.ingress.to_port\"), 22)",
    "contains_value(path(resource, \"security_groups.ingress.cidr_blocks\"), \"0.0.0.0/0\")"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "cis-aws-5.2",
    "exposure",
    "ec2",
    "network",
    "ssh"
  ],
  "remediation": "Remove public IP or restrict security group to specific IP ranges. Use AWS Systems Manager Session Manager for secure access.",
  "risk_categories": [
    "EXTERNAL_EXPOSURE"
  ],
  "frameworks": [
    {
      "name": "CIS AWS Foundations Benchmark v2.0",
      "controls": [
        "5.2"
      ]
