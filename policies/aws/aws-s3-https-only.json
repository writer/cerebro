{
  "id": "aws-s3-https-only",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "S3 Buckets Enforce HTTPS Only",
  "description": "S3 bucket policies should deny requests that are not made over HTTPS (SSL/TLS) to ensure data in transit is encrypted",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws_s3_buckets",
  "conditions": [
    "cmp_ne(path(resource, \"policy_requires_ssl\"), true)"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "cis-aws-2.1.2",
    "s3",
    "https",
    "ssl",
    "encryption-in-transit"
  ],
  "remediation": "Add a bucket policy that denies requests not using HTTPS. Include a statement with Condition: {\"Bool\": {\"aws:SecureTransport\": \"false\"}} and Effect: Deny",
  "remediation_steps": [
    "Navigate to S3 in AWS Console",
    "Select the bucket",
    "Go to 'Permissions' tab",
    "Edit 'Bucket policy'",
    "Add a statement denying non-SSL requests",
    "Example policy condition: {\"Bool\": {\"aws:SecureTransport\": \"false\"}}"
  ],
  "risk_categories": [
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "CIS AWS Foundations Benchmark v2.0",
      "controls": [
        "2.1.2"
      ]
    },
