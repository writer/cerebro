{
  "id": "aws-ecs-ssh-denied",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "ECS Services Deny Public SSH Access",
  "description": "ECS services should not allow public SSH access (port 22) through their associated security groups",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws_ecs_services",
  "conditions": [
    "cmp_eq(path(resource, \"allows_public_ssh\"), true)"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "ecs",
    "ssh",
    "security-groups",
    "network-security"
  ],
  "remediation": "Remove security group rules that allow inbound SSH (port 22) from 0.0.0.0/0 or ::/0 for ECS services",
  "remediation_steps": [
    "Identify security groups attached to the ECS service",
    "Find rules allowing port 22 from 0.0.0.0/0",
    "Remove or modify these rules",
    "Use SSM Session Manager or bastion hosts for administrative access instead"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "EXTERNAL_ATTACK_SURFACE"
  ],
