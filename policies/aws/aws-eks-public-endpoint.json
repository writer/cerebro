  "id": "aws-eks-public-endpoint-disabled",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "EKS Public Endpoint Disabled",
  "description": "EKS cluster API server endpoint should not be publicly accessible",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::eks::cluster",
  "conditions": [
    "cmp_eq(path(resource, \"resources_vpc_config.endpoint_public_access\"), true)",
