{
  "id": "aws-dynamodb-encryption",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "DynamoDB Table Not Encrypted with CMK",
  "description": "DynamoDB table is using default AWS-owned key instead of customer-managed KMS key",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::dynamodb::table",
  "conditions": [
    "(cmp_ne(path(resource, \"sse_description.sse_type\"), \"KMS\")) || (cmp_eq(path(resource, \"sse_description.kms_master_key_arn\"), null))"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "aws",
    "dynamodb",
    "encryption",
    "data-protection"
  ],
  "remediation": "Enable encryption with a customer-managed KMS key for sensitive data. Update the table's SSE specification.",
  "risk_categories": [
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "SC-12",
        "SC-13",
        "SC-28",
        "IA-5"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "4.2",
        "8.6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "3"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    },
    {
