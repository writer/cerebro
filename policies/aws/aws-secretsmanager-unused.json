{
  "id": "aws-secretsmanager-secret-used",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Secrets Manager Secret Used",
  "description": "Secrets Manager secrets should be accessed within 90 days",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::secretsmanager::secret",
  "conditions": [
    "cmp_gt(path(resource, \"last_accessed_date_days\"), 90)"
  ],
  "condition_format": "cel",
  "severity": "low",
