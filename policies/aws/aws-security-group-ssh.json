{
  "id": "aws-security-group-restrict-ssh",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Security Group SSH Restriction",
  "description": "Security groups should not allow unrestricted SSH access (0.0.0.0/0 on port 22)",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::ec2::security_group",
  "conditions": [
    "cmp_le(path(resource, \"ip_permissions.from_port\"), 22)",
    "cmp_ge(path(resource, \"ip_permissions.to_port\"), 22)",
    "contains_value(path(resource, \"ip_permissions.ip_ranges\"), \"0.0.0.0/0\")"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "cis-aws-5.2",
    "security-group",
    "network",
    "ssh",
    "remote-access"
  ],
  "remediation": "Restrict SSH access to specific IP ranges or use AWS Systems Manager Session Manager for remote access.",
  "risk_categories": [
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "CIS AWS Foundations Benchmark v2.0",
      "controls": [
        "5.2"
      ]
    },
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-2",
        "AC-6"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "7.2"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
