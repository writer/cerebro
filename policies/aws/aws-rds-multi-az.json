{
  "id": "aws-rds-multi-az-enabled",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "RDS Multi-AZ Enabled",
  "description": "RDS instances should have Multi-AZ enabled for high availability",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::rds::db_instance",
  "conditions": [
    "cmp_ne(path(resource, \"multi_az\"), true)",
    "cmp_ne(path(resource, \"engine\"), \"aurora\")"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "rds",
    "database",
    "availability",
    "disaster-recovery"
  ],
  "remediation": "Enable Multi-AZ deployment for the RDS instance.",
  "risk_categories": [
    "UNPROTECTED_DATA",
    "MISCONFIGURATION"
  ],
  "mitre_attack": [
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}
