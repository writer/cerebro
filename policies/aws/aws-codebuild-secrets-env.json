{
  "id": "aws-codebuild-secrets-in-env-vars",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "CodeBuild Secrets in Environment Variables",
  "description": "CodeBuild project has potential secrets stored in plaintext environment variables",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::codebuild::project",
  "conditions": [
    "matches_value(path(resource, \"environment.environment_variables.name\"), \"(?i)(password|secret|api_key|token|credential)\")",
    "cmp_eq(path(resource, \"environment.environment_variables.type\"), \"PLAINTEXT\")"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "secrets",
    "codebuild",
    "credentials",
    "cicd"
  ],
  "remediation": "Use PARAMETER_STORE or SECRETS_MANAGER type for sensitive environment variables.",
  "risk_categories": [
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "8.6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1078"
    },
    {
      "tactic": "Execution",
      "technique": "T1059"
    },
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    }
  ]
}
