{
  "id": "aws-codebuild-public-trigger",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "CodeBuild Project with Public Webhook",
  "description": "CodeBuild project has a public webhook that can be triggered by external sources",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::codebuild::project",
  "conditions": [
    "list_value(path(resource, \"webhook.filter_groups\")).exists(item, list_value(path(item, \"filters\")).exists(item, (cmp_eq(path(item, \"type\"), \"EVENT\")) \u0026\u0026 (contains_value(path(item, \"pattern\"), \"PULL_REQUEST\"))))",
    "in_list(path(resource, \"source.type\"), [\"GITHUB\",\"BITBUCKET\",\"GITLAB\"])"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "aws",
    "codebuild",
    "supply-chain",
    "ci-cd"
  ],
  "remediation": "Configure webhook filters to only accept events from trusted sources. Use branch filters and file path filters. Enable build badge but disable webhook for public repos.",
  "risk_categories": [
    "EXTERNAL_EXPOSURE"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-3",
        "SC-7"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "1.3",
        "1.4"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "12",
        "13"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1190"
    },
    {
      "tactic": "Execution",
      "technique": "T1059"
    }
  ]
}
