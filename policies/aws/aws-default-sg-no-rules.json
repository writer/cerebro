{
  "id": "aws-default-sg-no-rules",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Default Security Group Restricts All Traffic",
  "description": "The default security group in each VPC should have no inbound or outbound rules to ensure it cannot be accidentally used to allow unintended traffic",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws_ec2_security_groups",
  "conditions": [
    "cmp_eq(path(resource, \"group_name\"), path(resource, \"default\"))",
    "cmp_eq(path(resource, \"has_rules\"), true)"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "cis-aws-5.4",
    "security-groups",
    "vpc",
    "network-security"
  ],
  "remediation": "Remove all inbound and outbound rules from the default security group in each VPC",
  "remediation_steps": [
    "Navigate to VPC in AWS Console",
    "Select 'Security Groups'",
    "Find security groups named 'default'",
    "Select the default security group",
    "Remove all inbound rules",
    "Remove all outbound rules except the default egress rule (if required, remove that too)"
  ],
  "risk_categories": [
    "MISCONFIGURATION",
    "EXTERNAL_EXPOSURE"
  ],
  "frameworks": [
    {
      "name": "CIS AWS Foundations Benchmark v2.0",
