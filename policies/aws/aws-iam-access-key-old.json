  "id": "aws-iam-access-key-rotation",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "IAM Access Key Rotation",
  "description": "IAM access keys should be rotated within 90 days",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::iam::access_key",
  "conditions": [
    "cmp_gt(path(resource, \"create_date_days\"), 90)"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "cis-aws-1.14",
    "iam",
    "access-key",
    "rotation",
    "credentials"
  ],
  "remediation": "Rotate access keys by creating a new key, updating applications, and deleting the old key.",
