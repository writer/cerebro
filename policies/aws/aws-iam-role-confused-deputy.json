{
  "id": "aws-iam-role-confused-deputy-prevention",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "IAM Role Confused Deputy Prevention",
  "description": "IAM role trusted by AWS service should have ExternalId or SourceAccount condition",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::iam::role",
  "conditions": [
    "cmp_ne(path(resource, \"assume_role_policy_document.Statement.Principal.Service\"), null)",
    "cmp_eq(path(resource, \"assume_role_policy_document.Statement.Condition\"), null)",
    "!(contains_value(path(resource, \"path\"), \"/aws-service-role/\"))",
    "!(contains_value(path(resource, \"path\"), \"/aws-reserved/sso.amazonaws.com/\"))"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "iam",
    "trust-policy",
    "confused-deputy",
    "security"
  ],
  "remediation": "Add aws:SourceAccount or aws:SourceArn conditions to prevent confused deputy attacks.",
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "IDENTITY_RISK",
    "MISCONFIGURATION",
    "LATERAL_MOVEMENT"
  ],
  "frameworks": [
