{
  "id": "aws-iam-password-policy",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "IAM Password Policy Requirements",
  "description": "IAM password policy should enforce strong passwords with minimum length, complexity, and rotation requirements",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::iam::account_password_policy",
  "conditions": [
    "cmp_lt(path(resource, \"minimum_password_length\"), 14)",
    "cmp_ne(path(resource, \"require_symbols\"), true)",
    "cmp_ne(path(resource, \"require_numbers\"), true)",
    "cmp_ne(path(resource, \"require_uppercase_characters\"), true)",
    "cmp_ne(path(resource, \"require_lowercase_characters\"), true)",
    "cmp_gt(path(resource, \"max_password_age\"), 90)"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "cis-aws-1.8",
    "cis-aws-1.9",
    "cis-aws-1.10",
    "iam",
    "authentication"
  ],
  "remediation": "Update the IAM password policy to require minimum 14 characters, symbols, numbers, and uppercase/lowercase letters with 90-day rotation.",
  "risk_categories": [
    "IDENTITY_RISK",
    "MISCONFIGURATION"
  ],
  "frameworks": [
