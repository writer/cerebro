  "name": "Internet-Facing ALB Without WAF",
  "description": "Application Load Balancer is internet-facing without AWS WAF protection",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::elbv2::load_balancer",
  "conditions": [
    "cmp_eq(path(resource, \"scheme\"), \"internet-facing\")",
    "cmp_eq(path(resource, \"type\"), \"application\")",
    "cmp_eq(path(resource, \"waf_web_acl_arn\"), null)"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
