{
  "id": "aws-elb-https-only",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Load Balancer Listener Without HTTPS",
  "description": "Application or Network Load Balancer has a listener accepting unencrypted HTTP traffic",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws::elbv2::listener",
  "conditions": [
    "cmp_eq(path(resource, \"protocol\"), \"HTTP\")",
    "!(contains_value(path(resource, \"default_actions\"), \"type == 'redirect' AND redirect_config.protocol == 'HTTPS'\"))"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "aws",
    "elb",
    "encryption",
    "transport-security"
  ],
  "remediation": "Configure HTTP listeners to redirect to HTTPS. Remove plain HTTP listeners if not needed for redirects.",
  "risk_categories": [
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "SC-12",
        "SC-13",
        "SC-28"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "4.2"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "3"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Discovery",
      "technique": "T1087"
    }
  ]
}
