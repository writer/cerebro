{
  "id": "aws-nacl-admin-ports-restricted",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Network ACLs Restrict Admin Port Access",
  "description": "Network ACLs should not allow unrestricted ingress (0.0.0.0/0) to remote server administration ports (SSH port 22, RDP port 3389)",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "aws_ec2_network_acls",
  "conditions": [
    "cmp_eq(path(resource, \"allows_admin_ports_from_internet\"), true)"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "cis-aws-5.1",
    "nacl",
    "vpc",
    "network-security",
    "admin-access"
  ],
  "remediation": "Modify Network ACL rules to restrict access to ports 22 and 3389 from specific IP ranges only, not 0.0.0.0/0",
  "remediation_steps": [
    "Navigate to VPC in AWS Console",
    "Select 'Network ACLs'",
    "Review inbound rules for each NACL",
    "Identify rules allowing 0.0.0.0/0 to ports 22 or 3389",
    "Modify or remove these rules",
    "Add rules allowing access only from trusted IP ranges"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "EXTERNAL_ATTACK_SURFACE"
  ],
