{
  "id": "resolution-time-breach",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Zendesk Resolution Time SLA Breach",
  "description": "Flags tickets that breached resolution-time commitments while still unresolved.",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "zendesk::ticket",
  "conditions": [
    "cmp_eq(path(resource, \"resolution_sla_breached\"), true)",
    "cmp_ne(path(resource, \"status\"), \"closed\")"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "sla",
    "support",
    "zendesk"
  ]
}
