{
  "id": "container-runtime-exec-detected",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Container Runtime Exec Detected",
  "description": "kubectl exec or docker exec detected in production container",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "kubernetes::audit_event",
  "conditions": [
    "cmp_eq(path(resource, \"verb\"), \"create\")",
    "cmp_eq(path(resource, \"resource\"), \"pods/exec\")",
    "!(in_list(path(resource, \"namespace\"), [\"['kube-system']\"]))"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "runtime",
    "kubernetes",
    "container",
    "exec",
    "suspicious-activity"
  ],
  "remediation": "Review exec session for unauthorized access. Implement admission policies to restrict exec."
}
