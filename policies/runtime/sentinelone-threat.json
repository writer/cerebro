{
  "id": "sentinelone-threat-detected",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "SentinelOne Threat Detected",
  "description": "SentinelOne EDR detected threat on endpoint",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "sentinelone::threat",
  "conditions": [
    "cmp_ne(path(resource, \"threat_info.incident_status\"), \"resolved\")",
    "in_list(path(resource, \"threat_info.confidence_level\"), [\"['malicious\",\"suspicious']\"])"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "runtime",
    "edr",
    "sentinelone",
    "malware",
    "incident-response"
  ],
  "remediation": "Review threat in SentinelOne console and follow incident response playbook."
}
