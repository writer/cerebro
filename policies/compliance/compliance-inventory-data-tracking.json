{
  "id": "compliance-inventory-data-tracking",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Inventory Tracks Resources with User Data",
  "description": "Ensures infrastructure inventory identifies and tracks resources that contain or process user data",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "infrastructure_inventory",
  "conditions": [
    "in_list(path(resource, \"resource_type\"), [\"database\",\"storage\",\"data_warehouse\"])",
    "!exists_path(resource, \"contains_user_data\")"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "compliance",
    "inventory",
    "user-data",
    "privacy",
    "gdpr",
    "data-classification"
  ],
  "remediation": "Update inventory to track which resources contain user data. This is essential for GDPR, privacy compliance, and incident response.",
  "remediation_steps": [
    "Audit all data storage resources",
    "Classify resources based on data sensitivity",
    "Update inventory with data classification flags",
    "Implement data discovery tools for automated classification",
    "Review and update classifications quarterly"
  ],
  "risk_categories": [
    "UNCLASSIFIED_DATA"
  ],
  "frameworks": [
    {
      "name": "GDPR",
      "controls": [
        "Art.30",
        "Art.5"
      ]
    },
    {
      "name": "SOC 2",
