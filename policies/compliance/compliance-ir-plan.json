  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Incident Response Plan Exists",
  "description": "The organization should have a documented incident response plan that is reviewed and approved annually",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "compliance_documents",
  "conditions": [
    "cmp_eq(path(resource, \"document_type\"), path(resource, \"INCIDENT_RESPONSE_PLAN\"))",
    "cmp_ne(path(resource, \"approved\"), true)"
  ],
  "condition_format": "cel",
  "severity": "high",
  "tags": [
    "compliance",
    "incident-response",
    "documentation"
  ],
  "remediation": "Create, review, and approve an incident response plan that covers detection, containment, eradication, recovery, and lessons learned",
  "remediation_steps": [
    "Draft or update the incident response plan",
    "Include roles, responsibilities, and escalation paths",
    "Define incident classification and severity levels",
    "Document communication and notification procedures",
    "Get management approval and sign-off",
    "Schedule annual review"
  ],
