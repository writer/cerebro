{
  "id": "compliance-p1-security-issues",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "P1 Security Issues Resolved Timely",
  "description": "Ensures P1 (critical) security issues are resolved within SLA (24-48 hours)",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "security_issues",
  "conditions": [
    "cmp_eq(path(resource, \"priority\"), \"P1\")",
    "cmp_ne(path(resource, \"status\"), \"resolved\")",
    "cmp_lt(path(resource, \"created_at\"), \"NOW() - INTERVAL '48 hours'\")"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "compliance",
    "security-issues",
    "p1",
    "critical",
    "sla",
    "incident-response"
  ],
  "remediation": "Immediately escalate and resolve P1 security issues. Follow incident response procedures.",
  "remediation_steps": [
    "Acknowledge the P1 issue within 15 minutes",
    "Assemble incident response team",
    "Implement containment measures",
    "Apply fix or workaround",
    "Complete post-incident review"
  ],
  "risk_categories": [
    "UNMITIGATED_RISK"
  ],
  "frameworks": [
    {
      "name": "SOC 2",
      "controls": [
        "CC7.3",
        "CC7.4"
      ]
    },
    {
      "name": "ISO 27001:2022",
      "controls": [
        "A.5.24",
        "A.5.26"
      ]
    },
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IR-4",
        "IR-5"
      ]
    }
  ]
}
