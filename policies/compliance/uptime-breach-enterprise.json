{
  "id": "uptime-breach-enterprise",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Enterprise Uptime SLA Breach",
  "description": "Flags enterprise services whose 30-day uptime falls below contractual targets.",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "service::uptime",
  "conditions": [
    "cmp_eq(path(resource, \"plan_tier\"), \"enterprise\")",
    "cmp_lt(path(resource, \"uptime_pct_30d\"), 99.9)"
  ],
  "condition_format": "cel",
  "severity": "critical",
  "tags": [
    "sla",
    "uptime",
    "operations"
  ]
}
