{
  "id": "sf-close-date-slip",
  "last_modified": "0001-01-01T00:00:00Z",
  "name": "Close Date Pushed More Than Twice",
  "description": "Flags opportunities with repeated close-date slips while still open.",
  "effect": "forbid",
  "principal": "",
  "action": "",
  "resource": "salesforce::opportunity",
  "conditions": [
    "cmp_gt(path(resource, \"close_date_push_count\"), 2)",
    "cmp_ne(path(resource, \"StageName\"), \"Closed Won\")"
  ],
  "condition_format": "cel",
  "severity": "medium",
  "tags": [
    "forecasting",
    "pipeline-hygiene",
    "salesforce"
  ]
}
