#!/usr/bin/env bash
set -euo pipefail

if [ "${CEREBRO_SKIP_PRE_PUSH:-}" = "1" ]; then
  exit 0
fi

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 not found; cannot run DevEx pre-push checks"
  exit 1
fi

BASE_REF="${CEREBRO_DEVEX_BASE_REF:-origin/main}"

echo "devex: running changed-file pre-push preflight against ${BASE_REF}..."
python3 ./scripts/devex.py run --mode changed --base-ref "${BASE_REF}"
