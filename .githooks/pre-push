#!/usr/bin/env bash
set -euo pipefail

if [ "${CEREBRO_SKIP_PRE_PUSH:-}" = "1" ]; then
  exit 0
fi

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 not found; cannot run DevEx pre-push checks"
  exit 1
fi

resolve_base_ref() {
	local remote_name="$1"
	local remote_head=""
	local candidate=""
	local candidates=()

	if [ -n "${CEREBRO_DEVEX_BASE_REF:-}" ]; then
		printf '%s\n' "$CEREBRO_DEVEX_BASE_REF"
		return 0
	fi

	if remote_head=$(git symbolic-ref --quiet --short "refs/remotes/${remote_name}/HEAD" 2>/dev/null); then
		candidates+=("$remote_head")
	fi

	for candidate in "${remote_name}/main" writer/main origin/main evalops/main main; do
		candidates+=("$candidate")
	done

	for candidate in "${candidates[@]}"; do
		if git rev-parse --verify "$candidate" >/dev/null 2>&1 && git merge-base HEAD "$candidate" >/dev/null 2>&1; then
			printf '%s\n' "$candidate"
			return 0
		fi
	done

	echo "could not resolve a base ref for DevEx pre-push checks; set CEREBRO_DEVEX_BASE_REF explicitly" >&2
	return 1
}

REMOTE_NAME="${1:-origin}"
BASE_REF="$(resolve_base_ref "$REMOTE_NAME")"

echo "devex: running changed-file pre-push preflight against ${BASE_REF}..."
python3 ./scripts/devex.py run --mode changed --base-ref "${BASE_REF}"
