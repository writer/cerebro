#!/usr/bin/env bash
set -euo pipefail

# Ensure GOPATH/bin is in PATH
export PATH="${GOPATH:-$HOME/go}/bin:$PATH"

# Run goimports on staged .go files (excluding vendor)
mapfile -t STAGED_FILES < <(git diff --cached --name-only --diff-filter=ACM -- '*.go' | grep -v '^vendor/' || true)
if [ "${#STAGED_FILES[@]}" -eq 0 ]; then
  exit 0
fi

if ! command -v goimports &>/dev/null; then
  echo "goimports not found. Install with: go install golang.org/x/tools/cmd/goimports@latest"
  exit 1
fi

UNFORMATTED=$(goimports -l "${STAGED_FILES[@]}" 2>/dev/null || true)
if [ -n "$UNFORMATTED" ]; then
  echo "goimports: fixing formatting..."
  goimports -w ${UNFORMATTED}
  git add ${UNFORMATTED}
fi

if ! command -v golangci-lint &>/dev/null; then
  echo "golangci-lint not found. Install with: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@latest"
  exit 1
fi

mapfile -t STAGED_PACKAGE_DIRS < <(printf '%s\n' "${STAGED_FILES[@]}" | xargs -n1 dirname | sed 's#^\\.$#./#' | sort -u)

echo "golangci-lint: running fast checks on staged Go files..."
golangci-lint run --fast-only --timeout 2m "${STAGED_PACKAGE_DIRS[@]}"
