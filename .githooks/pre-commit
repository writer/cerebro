#!/usr/bin/env bash
set -euo pipefail

# Ensure GOPATH/bin is in PATH
export PATH="${GOPATH:-$HOME/go}/bin:$PATH"

# Run goimports on staged .go files (excluding vendor)
STAGED_FILES=()
while IFS= read -r file; do
	STAGED_FILES+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACM -- '*.go' | grep -v '^vendor/' || true)
if [ "${#STAGED_FILES[@]}" -eq 0 ]; then
  exit 0
fi

if ! command -v goimports &>/dev/null; then
  echo "goimports not found. Install with: go install golang.org/x/tools/cmd/goimports@latest"
  exit 1
fi

UNFORMATTED=$(goimports -l "${STAGED_FILES[@]}" 2>/dev/null || true)
if [ -n "$UNFORMATTED" ]; then
  echo "goimports: fixing formatting..."
  goimports -w ${UNFORMATTED}
  git add ${UNFORMATTED}
fi

if ! command -v golangci-lint &>/dev/null; then
  echo "golangci-lint not found. Install with: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@latest"
  exit 1
fi

STAGED_PACKAGE_DIRS=()
while IFS= read -r dir; do
	STAGED_PACKAGE_DIRS+=("$dir")
done < <(printf '%s\n' "${STAGED_FILES[@]}" | xargs -n1 dirname | sed 's#^\\.$#./#' | sort -u)

FILTERED_PACKAGE_DIRS=()
for dir in "${STAGED_PACKAGE_DIRS[@]}"; do
  list_dir="$dir"
  if [[ "$list_dir" != ./* && "$list_dir" != /* ]]; then
    list_dir="./$list_dir"
  fi
  if output=$(go list "$list_dir" 2>&1); then
    FILTERED_PACKAGE_DIRS+=("$list_dir")
    continue
  fi
  if [[ "$output" == *"build constraints exclude all Go files"* ]]; then
    continue
  fi
  echo "$output"
  exit 1
done

if [ "${#FILTERED_PACKAGE_DIRS[@]}" -eq 0 ]; then
  exit 0
fi

echo "golangci-lint: running fast checks on staged Go files..."
golangci-lint run --fast-only --timeout 2m "${FILTERED_PACKAGE_DIRS[@]}"
