#!/usr/bin/env bash
set -euo pipefail

# Run goimports on staged .go files (excluding vendor)
STAGED=$(git diff --cached --name-only --diff-filter=ACM -- '*.go' | grep -v '^vendor/' || true)
if [ -z "$STAGED" ]; then
  exit 0
fi

if ! command -v goimports &>/dev/null; then
  echo "goimports not found. Install with: go install golang.org/x/tools/cmd/goimports@latest"
  exit 1
fi

UNFORMATTED=$(echo "$STAGED" | xargs goimports -l 2>/dev/null || true)
if [ -n "$UNFORMATTED" ]; then
  echo "goimports: fixing formatting..."
  echo "$UNFORMATTED" | xargs goimports -w
  echo "$UNFORMATTED" | xargs git add
fi
